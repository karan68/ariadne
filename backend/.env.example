# --- Cognee target ---------------------------------------------------------
# Leave COGNEE_BASE_URL blank to run against local open-source Cognee.
# Set it (and the API key) to target Cognee Cloud via cognee.serve().
COGNEE_BASE_URL=
COGNEE_API_KEY=
COGNEE_TENANT_ID=
COGNEE_USER_ID=

# --- LLM (used by Cognee cognify for extraction) ---------------------------
LLM_PROVIDER=custom
LLM_MODEL=azure/gpt-5.4
LLM_ENDPOINT=
LLM_API_KEY=
AZURE_API_BASE=
AZURE_API_KEY=
AZURE_API_VERSION=

# --- Embeddings (local Ollama by default; no key needed) -------------------
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
HUGGINGFACE_TOKENIZER=bert-base-uncased

# --- Ariadne app -----------------------------------------------------------
ARIADNE_REF_LITERATURE=reference_literature
ARIADNE_REF_TRIALS=reference_trials
ARIADNE_MIN_CONFIDENCE=0.35

# --- Local Cognee stores ---------------------------------------------------
# Optional: override where local OSS Cognee keeps its graph/vector/relational
# state. If unset, Ariadne defaults these to backend/.cognee_data and
# backend/.cognee_system so its memory is isolated from other local projects.
DATA_ROOT_DIRECTORY=
SYSTEM_ROOT_DIRECTORY=

# --- Agent principals (Cloud RBAC; service API keys per agent) -------------
# Populated in P3 when agents are registered as their own Cognee principals.
AGENT_TIMELINE_KEY=
AGENT_CONNECTIONS_KEY=
AGENT_TRIALS_KEY=
AGENT_SAFETY_KEY=
AGENT_BRIEFING_KEY=
AGENT_JUSTIFY_KEY=
